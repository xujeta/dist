#:import MDLabel kivymd.uix.label.MDLabel
#:import MDRaisedButton kivymd.uix.button.MDRaisedButton
#:import MDFloatLayout kivymd.uix.floatlayout.MDFloatLayout
#:import MDBoxLayout kivymd.uix.boxlayout.MDBoxLayout
#:import MDTextField kivymd.uix.textfield.MDTextField
#:import MDSnackbar kivymd.uix.snackbar.MDSnackbar
#:import ProfileChart screens.result_screen.ProfileChart

<BeautifulButton@MDRaisedButton>:
    font_name: "Assets/fonts/Jura-Medium.ttf"
    md_bg_color: 0.37, 0.37, 0.37, 0.4
    font_size: "20sp"
    text_color: 1, 1, 1, 1
    elevation: 2
    padding: [dp(20), dp(10)]

<StartScreen>:
    MDBoxLayout:
        orientation: "vertical"
        padding: "20dp"
        spacing: "20dp"

        Widget:
            size_hint_y: 0.2

        MDLabel:
            text: "Настройки Map2Motion"
            halign: "center"
            font_name: "Assets/fonts/Jura-Bold.ttf"
            font_size: "30sp"
            size_hint_y: None
            height: self.texture_size[1]

        MDBoxLayout:
            orientation: "vertical"
            spacing: "15dp"
            size_hint_y: None
            height: self.minimum_height
            adaptive_height: True
            
            MDTextField:
                id: speed_input
                hint_text: "Скорость робота (км/ч)"
                text: "1.0"
                input_filter: "float"
                font_name: "Assets/fonts/Jura-Regular.ttf"

            MDTextField:
                id: t1_input
                hint_text: "Угол включения Реле 2 (град)"
                text: "30"
                input_filter: "int"
                font_name: "Assets/fonts/Jura-Regular.ttf"

            MDTextField:
                id: t2_input
                hint_text: "Угол включения Реле 3 (град)"
                text: "60"
                input_filter: "int"
                font_name: "Assets/fonts/Jura-Regular.ttf"

        BeautifulButton:
            text: "Старт"
            pos_hint: {"center_x": 0.5}
            on_release: root.start()

        Widget:
            size_hint_y: 0.3

<CameraScreen>:
    MDBoxLayout:
        orientation: "vertical"
        FloatLayout:
            BeautifulButton:
                text: "Открыть камеру"
                pos_hint: {"center_x": 0.5, "center_y": 0.65}
                on_release: app.open_camera()
            BeautifulButton:
                text: "Выбрать из галереи"
                pos_hint: {"center_x": 0.5, "center_y": 0.5}
                on_release: app.pick_from_gallery()
            BeautifulButton:
                text: "Назад"
                pos_hint: {"center_x": 0.35, "center_y": 0.25}
                on_release: app.go_back("start")
            BeautifulButton:
                text: "Вперед"
                pos_hint: {"center_x": 0.65, "center_y": 0.25}
                on_release: app.go_next("line")

<LineSelectScreen>:
    MDBoxLayout:
        orientation: "vertical"
        padding: "12dp"
        spacing: "12dp"
        
        MDBoxLayout:
            size_hint_y: 0.7
            LineImageWidget:
                id: line_widget
                source: root.image_path
                parent_screen: root
                
        MDBoxLayout:
            size_hint_y: None
            height: dp(60)
            spacing: "15dp"
            
            BeautifulButton:
                text: "Назад"
                size_hint_x: 0.35
                on_release: app.go_back("camera")

            BeautifulButton:
                text: "Построить профиль"
                size_hint_x: 0.65
                on_release: app.go_next("profile")

<ProfileScreen>:
    MDBoxLayout:
        orientation: "vertical"
        FloatLayout:
            MDLabel:
                text: "Обработка данных..."
                id: loading_label
                halign: "center"
                pos_hint: {"center_x": 0.5, "center_y": 0.6}
            BeautifulButton:
                text: "Отмена"
                pos_hint: {"center_x": 0.5, "center_y": 0.4}
                on_release: app.go_back("line")

<ResultScreen>:
    MDFloatLayout:
        
        MDLabel:
            text: "Профиль и Статус Робота"
            halign: "center"
            font_name: "Assets/fonts/Jura-Bold.ttf"
            font_size: "24sp"
            size_hint_y: None
            height: dp(50)
            pos_hint: {"center_x": 0.5, "top": 0.98}

        MDBoxLayout:
            size_hint: 0.9, 0.28 
            pos_hint: {"center_x": 0.5, "top": 0.88}
            md_bg_color: 0.1, 0.1, 0.1, 1
            radius: [20,]
            padding: "10dp"
            ProfileChart:
                id: chart

        MDBoxLayout:
            size_hint: 0.9, None
            height: dp(70)
            pos_hint: {"center_x": 0.5, "top": 0.58}
            spacing: "15dp"
            
            MDBoxLayout:
                orientation: 'vertical'
                Widget:
                    id: led1
                    size_hint: None, None
                    size: dp(35), dp(35)
                    pos_hint: {"center_x": 0.5}
                    canvas.before:
                        Color:
                            rgba: (0.2, 0.2, 0.2, 1)
                        Ellipse:
                            pos: self.pos
                            size: self.size
                MDLabel:
                    text: "R1 (База)"
                    halign: "center"
                    font_size: "12sp"

            MDBoxLayout:
                orientation: 'vertical'
                Widget:
                    id: led2
                    size_hint: None, None
                    size: dp(35), dp(35)
                    pos_hint: {"center_x": 0.5}
                    canvas.before:
                        Color:
                            rgba: (0.2, 0.2, 0.2, 1)
                        Ellipse:
                            pos: self.pos
                            size: self.size
                MDLabel:
                    text: f"R2 (>{int(app.angle_t1)}°)"
                    halign: "center"
                    font_size: "12sp"

            MDBoxLayout:
                orientation: 'vertical'
                Widget:
                    id: led3
                    size_hint: None, None
                    size: dp(35), dp(35)
                    pos_hint: {"center_x": 0.5}
                    canvas.before:
                        Color:
                            rgba: (0.2, 0.2, 0.2, 1)
                        Ellipse:
                            pos: self.pos
                            size: self.size
                MDLabel:
                    text: f"R3 (>{int(app.angle_t2)}°)"
                    halign: "center"
                    font_size: "12sp"

        MDBoxLayout:
            size_hint: 0.9, 0.25
            pos_hint: {"center_x": 0.5, "top": 0.45}
            md_bg_color: 0.05, 0.05, 0.05, 1 
            radius: [10,]
            padding: "10dp"
            ScrollView:
                id: scroll_view
                MDLabel:
                    id: console_log
                    text: "Готов к запуску. Ожидание команд..."
                    font_name: "Assets/fonts/Jura-Regular.ttf"
                    font_size: "14sp"
                    theme_text_color: "Custom"
                    text_color: 0, 1, 0, 1 
                    size_hint_y: None
                    height: self.texture_size[1]
                    halign: "left"
                    valign: "top"

        MDBoxLayout:
            orientation: "vertical"
            size_hint: 0.9, None
            height: dp(110)
            pos_hint: {"center_x": 0.5, "y": 0.03}
            spacing: "10dp"
            
            BeautifulButton:
                text: "НАЗАД"
                size_hint_x: 1  
                md_bg_color: 0.4, 0.4, 0.4, 0.8  
                on_release: app.go_back("start") 

            MDBoxLayout:
                spacing: "20dp"
                
                BeautifulButton:
                    text: "ЗАПУСК"
                    size_hint_x: 0.5
                    md_bg_color: 0, 0.6, 0, 0.8
                    on_release: root.start_simulation()

                BeautifulButton:
                    text: "СТОП"
                    size_hint_x: 0.5
                    md_bg_color: 0.8, 0, 0, 0.8
                    on_release: root.stop_simulation()

<StyledSnackbar@MDSnackbar>:
    size_hint_x: 0.85
    pos_hint: {"center_x": 0.5, "center_y": 0.08}
    md_bg_color: 0.25, 0.25, 0.25, 0.9
    radius: [20, 20, 20, 20]
    SnackbarLabel:
        id: label

<SnackbarLabel@MDLabel>:
    theme_text_color: "Custom"
    text_color: 1, 1, 1, 1
    font_name: "Assets/fonts/Jura-Medium.ttf"
